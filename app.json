{
  "expo": {
    "name": "Şartname Cepte",
    "slug": "sartname-cepte",
    "version": "0.5.0",
    "scheme": "sartnamecepte",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0B1F3A",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/branding/logo.png",
      "backgroundColor": "#0B1F3A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arjinkiran.sartnamecepte"
    },
    "android": {
      "package": "com.arjinkiran.sartnamecepte",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1F3A"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"]
  }
}
